<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <EnforceCodeStyleInBuild>true</EnforceCodeStyleInBuild>
    <AnalysisLevel>latest</AnalysisLevel>
    <NoWarn>$(NoWarn);CS1591;NU1902;NU1903</NoWarn>
    <RootNamespace>RelixQ.Scoring</RootNamespace>
    <AssemblyName>RelixQ.Scoring</AssemblyName>
  </PropertyGroup>

  <PropertyGroup>
    <IsPackable>true</IsPackable>
    <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
    <PackageId>RelixQ.Scoring</PackageId>
    <Version>0.1.0</Version>
    <Authors>Yasvanth Udayakumar</Authors>
    <Product>Relix-Q</Product>
    <Description>Pure scoring formula for basic. Deterministic 0..100 risk score over CryptoFinding inputs. Pure-function library: no DI, no host, no DB.</Description>
    <PackageLicenseExpression>Apache-2.0</PackageLicenseExpression>
    <Copyright>Copyright (c) 2026 Yasvanth Udayakumar</Copyright>
  </PropertyGroup>

</Project>
