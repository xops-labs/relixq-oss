<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <EnforceCodeStyleInBuild>true</EnforceCodeStyleInBuild>
    <AnalysisLevel>latest</AnalysisLevel>
    <NoWarn>$(NoWarn);CS1591;NU1902;NU1903</NoWarn>
    <RootNamespace>RelixQ.Contracts</RootNamespace>
    <AssemblyName>RelixQ.Contracts</AssemblyName>
  </PropertyGroup>

  <PropertyGroup>
    <IsPackable>true</IsPackable>
    <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
    <PackageId>RelixQ.Contracts</PackageId>
    <Version>0.1.0</Version>
    <Authors>Yasvanth Udayakumar</Authors>
    <Product>Relix-Q</Product>
    <Description>Canonical cross-service DTOs (CryptoFinding wire shape, scoring events) + JSON Schema as embedded resource. Pure data contracts; no runtime behavior.</Description>
    <PackageLicenseExpression>Apache-2.0</PackageLicenseExpression>
    <Copyright>Copyright (c) 2026 Yasvanth Udayakumar</Copyright>
  </PropertyGroup>

  <ItemGroup>
    <EmbeddedResource Include="schemas\CryptoFinding.json">
      <LogicalName>RelixQ.Contracts.Schemas.CryptoFinding.json</LogicalName>
    </EmbeddedResource>
  </ItemGroup>

</Project>
