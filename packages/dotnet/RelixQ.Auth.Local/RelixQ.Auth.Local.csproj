<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <EnforceCodeStyleInBuild>true</EnforceCodeStyleInBuild>
    <AnalysisLevel>latest</AnalysisLevel>
    <NoWarn>$(NoWarn);CS1591;NU1902;NU1903</NoWarn>
    <RootNamespace>RelixQ.Auth.Local</RootNamespace>
    <AssemblyName>RelixQ.Auth.Local</AssemblyName>
  </PropertyGroup>

  <PropertyGroup>
    <IsPackable>true</IsPackable>
    <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
    <PackageId>RelixQ.Auth.Local</PackageId>
    <Version>0.1.0</Version>
    <Authors>Yasvanth Udayakumar</Authors>
    <Product>Relix-Q</Product>
    <Description>local-credential primitives: Argon2id password hash + verify + rehash, zxcvbn password strength gate, opaque-token mint + at-rest hash for email verification and password reset. Pure functions over inputs; no DI, no host, no DB.</Description>
    <PackageLicenseExpression>Apache-2.0</PackageLicenseExpression>
    <Copyright>Copyright (c) 2026 Yasvanth Udayakumar</Copyright>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Konscious.Security.Cryptography.Argon2" Version="1.3.1" />
    <PackageReference Include="zxcvbn-core" Version="7.0.92" />
  </ItemGroup>

</Project>
