<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <EnforceCodeStyleInBuild>true</EnforceCodeStyleInBuild>
    <AnalysisLevel>latest</AnalysisLevel>
    <NoWarn>$(NoWarn);CS1591;NU1902;NU1903</NoWarn>
    <RootNamespace>RelixQ.AI.BYOK</RootNamespace>
    <AssemblyName>RelixQ.AI.BYOK</AssemblyName>
  </PropertyGroup>

  <PropertyGroup>
    <IsPackable>true</IsPackable>
    <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
    <PackageId>RelixQ.AI.BYOK</PackageId>
    <Version>0.1.0</Version>
    <Authors>Yasvanth Udayakumar</Authors>
    <Product>Relix-Q</Product>
    <Description>Bring-Your-Own-Key LLM provider adapters. Ships ILlmProvider + LlmRequest/LlmResult contracts, OpenAI and Anthropic adapters, a shared cost estimator, and an env-first API-key resolver. Bedrock / Vertex hosted providers, caches, migration-plan generator, and router are out of scope for this package.</Description>
    <PackageLicenseExpression>Apache-2.0</PackageLicenseExpression>
    <Copyright>Copyright (c) 2026 Yasvanth Udayakumar</Copyright>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="8.0.2" />
  </ItemGroup>

</Project>
