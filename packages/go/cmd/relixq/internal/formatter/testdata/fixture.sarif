{"version":"2.1.0","$schema":"https://raw.githubusercontent.com/oasis-tcs/sarif-spec/main/sarif-2.1/schema/sarif-schema-2.1.0.json","runs":[{"tool":{"driver":{"informationUri":"https://relixq.io","name":"relixq","rules":[{"id":"GO_RSA_GENERATE_KEY","shortDescription":{"text":"crypto/rsa.GenerateKey produces a quantum-vulnerable key pair."},"helpUri":"https://relixq.io/rules/GO_RSA_GENERATE_KEY","help":{"markdown":"crypto/rsa.GenerateKey produces a quantum-vulnerable key pair.\n\n- **Algorithm:** RSA (quantum safety: vulnerable)\n\n**Recommendation:** Migrate to ML-KEM (FIPS 203) or a hybrid X25519+ML-KEM construction.\n\n**References:**\n- https://csrc.nist.gov/pubs/fips/203/final"},"properties":{"security-severity":"9.5","tags":["security","cryptography","pqc","quantum-vulnerable","external/cwe/cwe-327"]}},{"id":"PY_AES_ECB_MODE","shortDescription":{"text":"AES in ECB mode leaks plaintext structure and is not IND-CPA secure."},"helpUri":"https://relixq.io/rules/PY_AES_ECB_MODE","help":{"markdown":"AES in ECB mode leaks plaintext structure and is not IND-CPA secure.\n\n- **Algorithm:** AES (quantum safety: vulnerable)\n\n**Recommendation:** Use AES-GCM with a 256-bit key, and plan for ML-KEM-derived keys."},"properties":{"security-severity":"8.1","tags":["security","cryptography","pqc","quantum-vulnerable","external/cwe/cwe-327","external/cwe/cwe-696"]}},{"id":"CSHARP_SHA1_CREATE","shortDescription":{"text":"SHA-1 is broken against collision attacks; quantum reduces its effective security further."},"helpUri":"https://relixq.io/rules/CSHARP_SHA1_CREATE","help":{"markdown":"SHA-1 is broken against collision attacks; quantum reduces its effective security further.\n\n- **Algorithm:** SHA1 (quantum safety: vulnerable)"},"properties":{"security-severity":"5.5","tags":["security","cryptography","pqc","quantum-vulnerable"]}},{"id":"JAVA_ECDSA_P256_SIGN","shortDescription":{"text":"ECDSA over P-256 is vulnerable to Shor's algorithm on a CRQC."},"helpUri":"https://relixq.io/rules/JAVA_ECDSA_P256_SIGN","help":{"markdown":"ECDSA over P-256 is vulnerable to Shor's algorithm on a CRQC.\n\n- **Algorithm:** ECDSA-P256 (quantum safety: vulnerable)"},"properties":{"security-severity":"3.0","tags":["security","cryptography","pqc","quantum-vulnerable"]}},{"id":"RUST_MLKEM_KEYGEN","shortDescription":{"text":"ML-KEM-768 keypair generation; recorded for inventory."},"helpUri":"https://relixq.io/rules/RUST_MLKEM_KEYGEN","help":{"markdown":"ML-KEM-768 keypair generation; recorded for inventory.\n\n- **Algorithm:** ML-KEM-768 (quantum safety: quantum_safe)"},"properties":{"security-severity":"1.0","tags":["security","cryptography"]}}]}},"results":[{"ruleId":"GO_RSA_GENERATE_KEY","ruleIndex":0,"level":"error","message":{"text":"crypto/rsa.GenerateKey produces a quantum-vulnerable key pair. Migrate to ML-KEM (FIPS 203) or a hybrid X25519+ML-KEM construction."},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"services/auth/keys.go"},"region":{"startLine":42}}}],"partialFingerprints":{"relixq/v1":"84eb4089ae0981c7575d037cc6f12354ca1da0e0836e3c36086617912f8b7e66"}},{"ruleId":"PY_AES_ECB_MODE","ruleIndex":1,"level":"error","message":{"text":"AES in ECB mode leaks plaintext structure and is not IND-CPA secure. Use AES-GCM with a 256-bit key, and plan for ML-KEM-derived keys."},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"apps/web/crypto/legacy.py"},"region":{"startLine":113}}}],"partialFingerprints":{"relixq/v1":"0726c5eadd5fc633ac0e95bc81083cdf3b6029e862388dd977f9774982c913cd"}},{"ruleId":"CSHARP_SHA1_CREATE","ruleIndex":2,"level":"warning","message":{"text":"SHA-1 is broken against collision attacks; quantum reduces its effective security further."},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"services/billing/Hashing.cs"},"region":{"startLine":27}}}],"partialFingerprints":{"relixq/v1":"4b23be0d0db2c4117158d07035ecf24530f8b407bac2e6bab55115b82ff09d7b"}},{"ruleId":"JAVA_ECDSA_P256_SIGN","ruleIndex":3,"level":"not