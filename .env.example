# Copy to .env to override. Every value has a sane default, so the stack runs
# unedited — `docker compose up --build` works with no .env at all.

# Host ports
WEB_PORT=47000
API_PORT=47080
POSTGRES_PORT=47432

# Postgres credentials (shared by the postgres and api containers)
POSTGRES_USER=relixq
POSTGRES_PASSWORD=relixq
POSTGRES_DB=relixq

# Host folder mounted (read-only) into the API for "Local path" projects. Put the
# code you want to scan here (or under subfolders); the default is ./scan-targets.
LOCAL_SCAN_PATH=./scan-targets
